# MCP Server for Power BI Environment Variables
# Copy this file to .env and fill in your values

# ===== OAuth/Entra ID Configuration =====
# HTTP server port (default: 3001)
PORT=3001

# Azure AD Tenant ID
TENANT_ID=your-tenant-id-here

# Application ID (client ID) that this MCP server is registered as
# This is the API application ID that receives tokens from LibreChat
AUDIENCE=your-api-app-id-here

# Client credentials for On-Behalf-Of (OBO) flow
# These credentials exchange user tokens for downstream Power BI/Fabric tokens
OBO_CLIENT_ID=your-obo-client-id-here
OBO_CLIENT_SECRET=your-obo-client-secret-here

# Alternative names (will use OBO_* if both are provided)
# CLIENT_ID=your-obo-client-id-here
# CLIENT_SECRET=your-obo-client-secret-here

# ===== Optional: Required Scopes and Roles =====
# Comma-separated list of required scopes in the access token
REQUIRED_SCOPES=mcp.access

# Comma-separated list of required roles in the access token
REQUIRED_ROLES=mcp.user

# ===== Logging =====
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ===== Test Client Configuration (for testing OAuth flow) =====
# Client application ID for testing
TESTCLIENT_CLIENT_ID=your-test-client-id-here

# Scopes to request when testing
TESTCLIENT_SCOPE="api://your-api-app-id/mcp.access openid profile offline_access"

